# ── Environment ────────────────────────────────────────────────────────────────
# "development" → Swagger UI (/docs, /redoc) enabled, verbose logging
# "production"  → Swagger UI blocked, WARNING-level logging, strict CORS + HSTS
ENVIRONMENT=development

# ── Google Generative AI ───────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GENERATION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Vector DB (Chroma) ─────────────────────────────────────────────────────────
CHROMA_DIR=backend/chroma_db
CHROMA_COLLECTION=python_qa

# ── RAG settings ───────────────────────────────────────────────────────────────
RETRIEVAL_K=5
MAX_RELEVANCE_DISTANCE=0.60

# ── CORS (comma-separated origins) ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGODB_DB_NAME=python_qa_db

# ── Authentication ─────────────────────────────────────────────────────────────
AUTH_USERNAME=Analytics Vidhya
AUTH_PASSWORD=Hire@2026
JWT_SECRET_KEY=change_this_to_a_strong_random_secret_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
