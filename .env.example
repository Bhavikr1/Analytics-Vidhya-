# ── Backend (copy to backend/.env) ──────────────────────────────────────────

# Google AI Studio API key — used for BOTH generation (gemini-2.0-flash)
# and embeddings (text-embedding-004). Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Models (defaults shown — override only if needed)
GENERATION_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004

# Persistent Chroma vector index location (created by scripts/ingest.py)
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=python_qa

# Retrieval tuning
RETRIEVAL_K=5
# Cosine distance above this => question treated as out of knowledge base
MAX_RELEVANCE_DISTANCE=0.60

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── Frontend (copy to frontend/.env.local) ──────────────────────────────────

# Base URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000
